# New Game Plus — .gitignore

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
ENV/
env/

# --- Testing & coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
*.prof

# --- IDE / editors ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Game assets (generated / compiled) ---
assets/compiled/
assets/cache/

# --- Chunk save data (generated at runtime) ---
saves/
world_data/

# --- Logs ---
*.log
logs/
